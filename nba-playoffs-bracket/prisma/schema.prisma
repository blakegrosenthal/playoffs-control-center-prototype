generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Participant {
  id           String            @id @default(cuid())
  clientId     String            @unique
  displayName  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  PoolParticipant[]
  entries      Entry[]
  createdPools Pool[]            @relation("PoolCreator")
}

model Pool {
  id                 String            @id @default(cuid())
  name               String
  description        String?
  inviteCode         String            @unique
  tiebreakerQuestion String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  lockTime           DateTime
  createdById        String?
  createdBy          Participant?      @relation("PoolCreator", fields: [createdById], references: [id], onDelete: SetNull)
  participants       PoolParticipant[]
  entries            Entry[]

  @@index([inviteCode])
}

model PoolParticipant {
  id            String      @id @default(cuid())
  poolId        String
  participantId String
  joinedAt      DateTime    @default(now())
  pool          Pool        @relation(fields: [poolId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([poolId, participantId])
  @@index([participantId])
}

model Entry {
  id               String      @id @default(cuid())
  poolId           String
  participantId    String
  displayName      String
  entryName        String
  picksJson        String      @default("{}")
  finalsTiebreaker Int?
  submittedAt      DateTime?
  score            Int         @default(0)
  correctWinners   Int         @default(0)
  exactLengths     Int         @default(0)
  pending          Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  pool             Pool        @relation(fields: [poolId], references: [id], onDelete: Cascade)
  participant      Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([poolId, submittedAt])
  @@index([participantId])
}

model SharedState {
  id          Int      @id
  resultsJson String
  updatedAt   DateTime @updatedAt
}
